---
layout: none
---
<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="/feed.xsl"?>
<rss version="2.0">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <link>{{ site.url }}</link>
    <description>{{ site.description | xml_escape }}</description>
    <lastBuildDate>{{ site.posts.first.date | default: site.time | date: "%a, %d %b %Y %H:%M:%S %z" }}</lastBuildDate>
    <lastUpdated>{{ site.posts.first.date | default: site.time | date: "%Y.%m.%d" }}</lastUpdated>
    {% for post in site.posts limit:10 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ site.url }}{{ post.url }}</link>
      <guid>{{ site.url }}{{ post.url }}</guid>
      <pubDate>{{ post.date | date: "%a, %d %b %Y %H:%M:%S %z" }}</pubDate>
      <description>{{ post.excerpt | strip_html | normalize_whitespace | xml_escape }}</description>
    </item>
    {% endfor %}
  </channel>
</rss>
