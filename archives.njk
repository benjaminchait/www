---
layout: page.njk
title: Archives
permalink: /archives/
---
<ul class="posts">
  {% for post in collections.posts | reverse %}
    <li>
      <a href="{% if post.data.external %}{{ post.data.external }}{% else %}{{ post.url }}{% endif %}"><span class="title">{{ post.data.title }}</span></a> <span class="date">{{ post.date | dateFormat }}</span>
    </li>
  {% endfor %}
</ul>
