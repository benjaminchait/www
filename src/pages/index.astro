---
import { getCollection, getEntry, render } from "astro:content";
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
import site from "../../_data/site.json";

const home = await getEntry("pages", "index");
const { Content } = await render(home);

const posts = (await getCollection("posts", (p) => p.data.published))
  .sort((a, b) => a.data.date - b.data.date);
const recentPosts = [...posts].reverse().slice(0, 3);
---
<Base description={home.data.description} path="/">
  <header>
    <h1>{site.title}</h1>
  </header>

  <main>

    <Content />

    {posts.length > 0 && (
      <>
        <hr />

        <h2>Recent posts</h2>
        <ul class="more-space">
          {recentPosts.map((post) => (
            <li><a class="post-link" href={post.data.permalink}>{post.data.title}</a></li>
          ))}
        </ul>
      </>
    )}

  </main>

  <Footer />
</Base>
